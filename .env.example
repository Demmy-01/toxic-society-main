# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES TEMPLATE
# ─────────────────────────────────────────────────────────────────────────────
# Copy this to .env.local and fill in your actual values
# WARNING: .env.local is in .gitignore and will NOT be committed (for security)

# ─── PAYSTACK (Payment Gateway) ──────────────────────────────────────────────
# Get these from: https://dashboard.paystack.com/settings/developers
# SECURITY: Public key is safe on client; Secret key MUST stay server-only

# Public key - used in CheckoutModal.tsx for the payment popup
# Used by: /src/app/components/CheckoutModal.tsx (CLIENT-SIDE - SAFE)
# Get from Paystack Dashboard: https://dashboard.paystack.com/settings/developers
VITE_PAYSTACK_PUBLIC_KEY=pk_live_[your-paystack-public-key-here]

# Secret key - used ONLY on server for payment verification
# NEVER expose this to the client or frontend
# Used by:
#   - /api/verify-payment.ts (Vercel serverless function)
#   - supabase/functions/paystack-verify/index.ts (Supabase edge function)
# Get from Paystack Dashboard: https://dashboard.paystack.com/settings/developers
PAYSTACK_SECRET_KEY=sk_live_[your-paystack-secret-key-here]

# ─── SUPABASE (Database & Authentication) ────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous/public key (safe for client-side usage)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── RESEND (Email Service - Optional) ─────────────────────────────────────────
# Get this from: https://resend.com/api-keys
# Used by: supabase/functions/send-campaign/index.ts
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY NOTES
# ─────────────────────────────────────────────────────────────────────────────
# 1. Keys prefixed with VITE_ are embedded in the frontend bundle (MUST be public)
# 2. Keys without VITE_ are server-only (never exposed to clients)
# 3. Never commit .env.local, .env.development, or any secrets
# 4. For production, set environment variables in:
#    - Vercel Dashboard: Settings > Environment Variables
#    - Supabase Dashboard: Project Settings > Secrets
#    - Ensure PAYSTACK_SECRET_KEY is set in BOTH Vercel AND Supabase
